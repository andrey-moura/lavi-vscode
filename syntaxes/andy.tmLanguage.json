{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "andy",
	"patterns": [
		{
			"name": "string.quoted.double.andylang",
			"match": "\"([^\"\\\\]|\\\\.)*\""
		},
		{
			"name": "string.quoted.single.andylang",
			"match": "'([^'\\\\]|\\\\.)*'"
		}
	],
	"repository": {},
	"scopeName": "source.andy"
}